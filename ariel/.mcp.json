{
  "mcpServers": {
    "nasa-ads": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/Users/akim/Projects/nasa-ads-mcp",
        "run",
        "python",
        "src/nasa_ads_mcp/server.py"
      ],
      "env": {
        "ADS_API_TOKEN": "${ADS_API_TOKEN}"
      }
    }
  },
  
  "servers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "requestInit": {
        "headers": {
          "Authorization": "Bearer ${GITHUB_PAT}"
        }
      }
    }
  }

}